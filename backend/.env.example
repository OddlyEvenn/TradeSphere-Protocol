# Backend Environment Variables Example

# Server Configuration
PORT=5000
NODE_ENV=development

# Database Configuration (PostgreSQL / Neon)
DATABASE_URL="postgresql://user:password@host:port/dbname?sslmode=require"

# Authentication
JWT_SECRET="your_secure_random_secret"

# Blockchain Configuration (Alchemy / Polygon / Sepolia)
ALCHEMY_RPC_URL="https://polygon-amoy.g.alchemy.com/v2/YOUR_API_KEY"
SEPOLIA_RPC_URL="https://eth-sepolia.g.alchemy.com/v2/YOUR_API_KEY"
PRIVATE_KEY="0x_your_private_key_here"

# Smart Contract Addresses
TRADE_REGISTRY_ADDRESS=0x...
LETTER_OF_CREDIT_ADDRESS=0x...
DOCUMENT_VERIFICATION_ADDRESS=0x...
PAYMENT_SETTLEMENT_ADDRESS=0x...

# IPFS Configuration (Pinata)
PINATA_API_KEY="your_pinata_api_key"
PINATA_SECRET_API_KEY="your_pinata_secret_api_key"

# Services
REDIS_URL=redis://localhost:6379
BREVO_API_KEY="your_brevo_api_key"

# CORS Configuration
FRONTEND_URLS=http://localhost:5173
